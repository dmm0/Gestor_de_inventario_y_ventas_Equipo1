<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<VBox maxHeight="-Infinity" maxWidth="-Infinity"
      minHeight="-Infinity" minWidth="-Infinity"
      prefHeight="550.0" prefWidth="600.0"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controladores.GenerarNotaRemisionController">
   <children>

      <!-- HEADER -->
      <HBox prefHeight="39.0" prefWidth="600.0" style="-fx-background-color: D4C6C3;">
         <children>
            <Button text="← Menú" onAction="#regresarMenu" style="-fx-background-color: #A3E0E6;">
               <HBox.margin><Insets left="10.0" top="8.0"/></HBox.margin>
            </Button>
            <Label text="Generar Nota de Remisión">
               <HBox.margin><Insets left="20.0" top="10.0"/></HBox.margin>
            </Label>
            <Region HBox.hgrow="ALWAYS"/>
         </children>
      </HBox>

      <!-- INFO GENERAL -->
      <HBox spacing="30.0" style="-fx-background-color: C3D3D4; -fx-background-radius: 20;">
         <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/></padding>
         <children>
            <!-- FOLIO -->
            <HBox>
               <children>
                  <VBox>
                     <children>
                        <Label text="Folio" style="-fx-font-weight: bold;"/>
                        <Label fx:id="lblFolio" text="---"/>
                     </children>
                  </VBox>
               </children>
            </HBox>

            <!-- FECHA -->
            <HBox>
               <children>
                  <VBox>
                     <children>
                        <Label text="Fecha:" style="-fx-font-weight: bold;"/>
                        <Label fx:id="lblFecha" text="--/--/--"/>
                     </children>
                  </VBox>
               </children>
            </HBox>

            <!-- CLIENTE -->
            <HBox>
               <children>
                  <VBox>
                     <children>
                        <Label text="Cliente:" style="-fx-font-weight: bold;"/>
                        <Label fx:id="lblCliente" text="Cargando..."/>
                     </children>
                  </VBox>
               </children>
            </HBox>
         </children>
         <VBox.margin><Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/></VBox.margin>
      </HBox>

      <!-- PRODUCTOS -->
      <VBox style="-fx-background-color: C3D3D4;" VBox.vgrow="ALWAYS">
         <padding><Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/></padding>
         <children>
            <Label text="Resumen de productos" style="-fx-font-weight: bold;"/>
            <HBox spacing="5" style="-fx-background-color: #BDC9CA;">
               <children>
                  <Label text="Cant." prefWidth="60.0"/>
                  <Label text="Descripción" prefWidth="240.0"/>
                  <Label text="Precio Unit." prefWidth="110.0"/>
                  <Label text="Importe" prefWidth="110.0"/>
               </children>
               <padding><Insets left="5.0"/></padding>
            </HBox>
            <ScrollPane fitToWidth="true" prefHeight="200.0">
               <content>
                  <VBox fx:id="contenedorProductos" spacing="5">
                     <padding><Insets left="5.0" top="5.0"/></padding>
                  </VBox>
               </content>
            </ScrollPane>
         </children>
      </VBox>

      <!-- TOTALES -->
      <VBox alignment="CENTER_RIGHT" spacing="5.0">
         <padding><Insets right="20.0" top="10.0" bottom="10.0"/></padding>
         <children>
            <HBox alignment="CENTER_RIGHT" spacing="10">
               <Label text="Subtotal:"/>
               <Label fx:id="lblSubtotal" text="\$ 0.00" style="-fx-font-weight: bold;"/>
            </HBox>
            <Separator maxWidth="200"/>
            <HBox alignment="CENTER_RIGHT" spacing="10">
               <Label text="Total:" style="-fx-font-size: 14px;"/>
               <Label fx:id="lblTotal" text="\$ 0.00" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
            </HBox>
         </children>
      </VBox>

      <!-- BOTONES -->
      <HBox alignment="CENTER" spacing="20.0">
         <padding><Insets bottom="20.0" top="10.0"/></padding>
         <children>
            <Button onAction="#generarNota" prefWidth="200.0" text="Generar Nota" 
                    style="-fx-background-color: #A3E0E6; -fx-font-weight: bold; -fx-cursor: hand;"/>
            <Button text="Cancelar" onAction="#regresarMenu" style="-fx-cursor: hand;"/>
         </children>
      </HBox>
   </children>
</VBox>