<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="550.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controladores.GenerarNotaRemisionController">
   <children>

      <!-- HEADER -->
      <HBox prefHeight="39.0" prefWidth="600.0" style="-fx-background-color: D4C6C3;">
         <children>
            <Button onAction="#regresarMenu" style="-fx-background-color: #A3E0E6;" text="← Menú">
               <HBox.margin><Insets left="10.0" top="8.0" /></HBox.margin>
            </Button>
            <Label text="Generar Nota de Remisión">
               <HBox.margin><Insets left="20.0" top="10.0" /></HBox.margin>
            </Label>
            <Region HBox.hgrow="ALWAYS" />
         </children>
      </HBox>

      <!-- INFO GENERAL -->
      <HBox spacing="30.0" style="-fx-background-color: C3D3D4; -fx-background-radius: 20;">
         <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
         <children>
            <!-- FOLIO -->
            <HBox>
               <children>
                  <VBox>
                     <children>
                        <Label style="-fx-font-weight: bold;" text="Folio" />
                        <Label fx:id="lblFolio" text="---" />
                     </children>
                  </VBox>
               </children>
            </HBox>

            <!-- FECHA -->
            <HBox>
               <children>
                  <VBox>
                     <children>
                        <Label style="-fx-font-weight: bold;" text="Fecha:" />
                        <Label fx:id="lblFecha" text="--/--/--" />
                     </children>
                  </VBox>
               </children>
            </HBox>

            <!-- CLIENTE -->
            <HBox>
               <children>
                  <VBox>
                     <children>
                        <Label style="-fx-font-weight: bold;" text="Cliente:" />
                        <Label fx:id="lblCliente" text="Publico General" />
                     </children>
                  </VBox>
               </children>
            </HBox>
         </children>
         <VBox.margin><Insets bottom="10.0" left="10.0" right="10.0" top="10.0" /></VBox.margin>
      </HBox>

      <!-- PRODUCTOS -->
      <VBox style="-fx-background-color: C3D3D4;" VBox.vgrow="ALWAYS">
         <padding><Insets bottom="10.0" left="10.0" right="10.0" top="10.0" /></padding>
         <children>
            <Label style="-fx-font-weight: bold;" text="Resumen de productos" />
            <HBox spacing="5" style="-fx-background-color: #BDC9CA;">
               <children>
                  <TableView fx:id="table_carrito" prefHeight="307.0" prefWidth="575.0">
                    <columns>
                      <TableColumn fx:id="col_cantidad" prefWidth="104.0" text="Cantidad" />
                      <TableColumn fx:id="col_descripcion" minWidth="0.0" prefWidth="232.0" text="Descripcion" />
                        <TableColumn fx:id="col_precioUnit" minWidth="3.0" prefWidth="115.0" text="Precio Unit." />
                        <TableColumn fx:id="col_importe" minWidth="0.0" prefWidth="123.0" text="Importe" />
                    </columns>
                  </TableView>
               </children>
               <padding><Insets left="5.0" /></padding>
            </HBox>
         </children>
      </VBox>

      <!-- TOTALES -->
      <VBox alignment="CENTER_RIGHT" spacing="5.0">
         <padding><Insets bottom="10.0" right="20.0" top="10.0" /></padding>
         <children>
            <HBox alignment="CENTER_RIGHT" spacing="10">
               <Label text="Subtotal:" />
               <Label fx:id="lblSubtotal" style="-fx-font-weight: bold;" text="\$ 0.00" />
            </HBox>
            <Separator maxWidth="200" />
            <HBox alignment="CENTER_RIGHT" spacing="10">
               <Label style="-fx-font-size: 14px;" text="Total:" />
               <Label fx:id="lblTotal" style="-fx-font-weight: bold; -fx-font-size: 14px;" text="\$ 0.00" />
            </HBox>
         </children>
      </VBox>

      <!-- BOTONES -->
      <HBox alignment="CENTER" spacing="20.0">
         <padding><Insets bottom="20.0" top="10.0" /></padding>
         <children>
            <Button onAction="#generarNota" prefWidth="200.0" style="-fx-background-color: #A3E0E6; -fx-font-weight: bold; -fx-cursor: hand;" text="Generar Nota" />
            <Button onAction="#regresarMenu" style="-fx-cursor: hand;" text="Cancelar" />
         </children>
      </HBox>
   </children>
</VBox>
