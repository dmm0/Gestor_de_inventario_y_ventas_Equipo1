<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefWidth="480.0"
      spacing="0.0"
      style="-fx-background-color: white; -fx-border-color: #A3E0E6; -fx-border-width: 2;"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controladores.RegistrarNuevoProductoController">

   <children>

      <!-- ENCABEZADO -->
      <HBox alignment="CENTER_LEFT"
            prefHeight="60.0"
            spacing="10.0"
            style="-fx-background-color: #A3E0E6;">

         <children>

            <Button onAction="#regresarMenu"
                    style="-fx-background-color: #A3E0E6; -fx-font-weight: bold; -fx-cursor: hand;"
                    text="← Menú" />

            <Separator orientation="VERTICAL" />

            <Label text="Gestión de Inventario - Nuevo Producto"
                   textFill="#2c3e50">

               <font>
                  <Font name="System Bold" size="20.0" />
               </font>

            </Label>

         </children>

         <padding>
            <Insets left="20.0" right="20.0" />
         </padding>

      </HBox>

      <!-- CONTENIDO -->
      <VBox spacing="15.0">

         <children>

            <!-- ID -->
            <VBox spacing="5.0">

               <children>

                  <Label text="ID del Producto (Manual):"
                         textFill="#555555">

                     <font>
                        <Font name="System Bold" size="13.0" />
                     </font>

                  </Label>

                  <TextField fx:id="txtId"
                             prefHeight="35.0"
                             promptText="Ingrese el ID numérico..."
                             style="-fx-background-radius: 5; -fx-border-color: #dcdde1; -fx-border-radius: 5;" />

               </children>

            </VBox>

            <!-- NOMBRE -->
            <VBox spacing="5.0">

               <children>

                  <Label text="Nombre / Descripción:"
                         textFill="#555555">

                     <font>
                        <Font name="System Bold" size="13.0" />
                     </font>

                  </Label>

                  <TextField fx:id="txtNombre"
                             prefHeight="35.0"
                             promptText="Nombre del producto..."
                             style="-fx-background-radius: 5; -fx-border-color: #dcdde1; -fx-border-radius: 5;" />

               </children>

            </VBox>

            <!-- STOCK Y PRECIO -->
            <HBox spacing="15.0">

               <children>

                  <!-- STOCK -->
                  <VBox spacing="5.0"
                        HBox.hgrow="ALWAYS">

                     <children>

                        <Label text="Cantidad (Stock):"
                               textFill="#555555">

                           <font>
                              <Font name="System Bold" size="13.0" />
                           </font>

                        </Label>

                        <HBox spacing="5.0">

                           <children>

                              <TextField fx:id="txtStock"
                                         prefHeight="35.0"
                                         prefWidth="100.0"
                                         promptText="0.0"
                                         style="-fx-background-radius: 5; -fx-border-color: #dcdde1; -fx-border-radius: 5;" />

                              <ComboBox fx:id="comboUnidad"
                                        prefHeight="35.0"
                                        prefWidth="110.0"
                                        style="-fx-background-radius: 5;" />

                           </children>

                        </HBox>

                     </children>

                  </VBox>

                  <!-- PRECIO -->
                  <VBox spacing="5.0"
                        HBox.hgrow="ALWAYS">

                     <children>

                        <Label text="Precio Unitario:"
                               textFill="#555555">

                           <font>
                              <Font name="System Bold" size="13.0" />
                           </font>

                        </Label>

                        <TextField fx:id="txtPrecio"
                                   prefHeight="35.0"
                                   promptText="0.00"
                                   style="-fx-background-radius: 5; -fx-border-color: #dcdde1; -fx-border-radius: 5;" />

                     </children>

                  </VBox>

               </children>

            </HBox>

            <!-- BOTONES -->
            <HBox alignment="CENTER"
                  spacing="20.0">

               <children>

                  <Button fx:id="btnGuardar"
                          onAction="#guardarProducto"
                          prefHeight="40.0"
                          prefWidth="160.0"
                          style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 5;"
                          text="GUARDAR" />

                  <Button fx:id="btnLimpiar"
                          onAction="#limpiarCampos"
                          prefHeight="40.0"
                          prefWidth="160.0"
                          style="-fx-background-color: #f44336; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 5;"
                          text="LIMPIAR" />

               </children>

               <padding>
                  <Insets top="15.0" />
               </padding>

            </HBox>

         </children>

         <padding>
            <Insets bottom="30.0"
                    left="30.0"
                    right="30.0"
                    top="20.0" />
         </padding>

      </VBox>

   </children>

</VBox>