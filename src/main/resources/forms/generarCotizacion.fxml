<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10"
      prefWidth="900"
      prefHeight="650"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controladores.GenerarCotizacionController"
      style="-fx-background-color:#F0F8FA;">

    <padding>
        <Insets top="15" right="15" bottom="15" left="15"/>
    </padding>

    <!-- HEADER -->
    <HBox spacing="20" alignment="CENTER_LEFT">

        <Button text="← Menú"
                onAction="#regresarMenu"
                style="-fx-background-color:#A3E0E6;" />

        <Label text="Generar Cotización"
               style="-fx-font-size:22px;
                      -fx-font-weight:bold;" />

        <Region HBox.hgrow="ALWAYS"/>

        <VBox>
            <Label text="Folio"/>
            <Label fx:id="lblFolio"
                   text="COT-0001"
                   style="-fx-font-weight:bold;"/>
        </VBox>

    </HBox>

    <!-- CLIENTE -->
    <GridPane hgap="10" vgap="10">

        <Label text="Nombre:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="txtNombre"
                   GridPane.rowIndex="0"
                   GridPane.columnIndex="1"/>

        <Label text="Teléfono:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
        <TextField fx:id="txtTelefono"
                   GridPane.rowIndex="0"
                   GridPane.columnIndex="3"/>

        <Label text="Correo:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="txtCorreo"
                   GridPane.rowIndex="1"
                   GridPane.columnIndex="1"
                   GridPane.columnSpan="3"/>

    </GridPane>

    <!-- BOTONES -->
    <HBox spacing="10">

        <Button text="Agregar Producto"
                onAction="#buscarProducto"
                style="-fx-background-color:#A3E0E6;" />

        <Button text="Editar Cantidad"
                onAction="#editarCantidad"/>

        <Button text="Quitar Producto"
                onAction="#eliminarProducto"
                style="-fx-background-color:#FFB3B3;" />

    </HBox>

    <!-- TABLA -->
    <TableView fx:id="tablaCotizacion" VBox.vgrow="ALWAYS">

        <columns>

            <TableColumn fx:id="colDescripcion"
                         text="Producto"
                         prefWidth="320"/>

            <TableColumn fx:id="colCantidad"
                         text="Cantidad"
                         prefWidth="100"/>

            <TableColumn fx:id="colPrecio"
                         text="Precio"
                         prefWidth="120"/>

            <TableColumn fx:id="colImporte"
                         text="Importe"
                         prefWidth="120"/>

        </columns>

    </TableView>

    <!-- IVA Y DESCUENTO -->
    <HBox spacing="30">

        <VBox spacing="5">

            <Label text="IVA (%)"/>
            <TextField fx:id="txtIVA"
                       promptText="16"/>

        </VBox>

        <VBox spacing="5">

            <Label text="Descuento (%)"/>
            <TextField fx:id="txtDescuento"
                       promptText="0"/>

        </VBox>

        <Button text="Aplicar"
                onAction="#calcularTotal"
                style="-fx-background-color:#A3E0E6;" />

    </HBox>

    <!-- TOTALES -->
    <VBox alignment="CENTER_RIGHT" spacing="5">

        <Label fx:id="lblSubtotal"
               text="Subtotal: $0.00"/>

        <Label fx:id="lblIVA"
               text="IVA: $0.00"/>

        <Label fx:id="lblDescuento"
               text="Descuento: $0.00"/>

        <Label fx:id="lblTotal"
               text="TOTAL: $0.00"
               style="-fx-font-size:18px;
                      -fx-font-weight:bold;" />

    </VBox>

    <!-- BOTONES FINALES -->
    <HBox spacing="15" alignment="CENTER">

        <Button text="Guardar Cotización"
                onAction="#guardarCotizacion"
                style="-fx-background-color:#A3E0E6;" />

        <Button text="Generar PDF"
                onAction="#generarPDF"
                style="-fx-background-color:#A3E0E6;" />

        <Button text="Enviar Correo"
                onAction="#enviarCorreo"
                style="-fx-background-color:#A3E0E6;" />

        <Button text="Convertir a Venta"
                onAction="#convertirAVenta"
                style="-fx-background-color:#C3E6A3;" />

    </HBox>

</VBox>