<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="400.0" prefWidth="301.0" spacing="20.0"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controladores.InicioSesionController">

   <children>

      <Label text="Triates Papelería" textAlignment="CENTER" maxWidth="1.7976931348623157E308">
         <font>
            <Font size="24.0" />
         </font>
      </Label>

      <Label text="Sistema de gestión" textAlignment="CENTER" maxWidth="1.7976931348623157E308">
         <font>
            <Font size="15.0" />
         </font>
      </Label>

      <Label text="Usuario" />
      <TextField fx:id="txtUsuario" promptText="Ingrese usuario"/>

      <Label text="Contraseña" />

      <!-- Contenedor para mostrar/ocultar -->
      <HBox spacing="5">
         <StackPane HBox.hgrow="ALWAYS">

            <!-- Oculta -->
            <PasswordField fx:id="txtPassword" promptText="Ingrese contraseña"/>

            <!-- Visible -->
            <TextField fx:id="txtPasswordVisible" promptText="Ingrese contraseña" visible="false"/>

         </StackPane>

         <!-- Botón toggle -->
         <Button text="👁" onAction="#togglePassword"/>
      </HBox>

      <Button text="Iniciar Sesión"
        maxWidth="1.7976931348623157E308"
        onAction="#iniciarSesion"
        style="-fx-background-color: #A3E0E6; -fx-cursor: hand; -fx-font-weight: bold;"/>

      <Separator prefWidth="200.0" />

   </children>

   <padding>
      <Insets bottom="20.0" left="19.0" right="20.0" top="20.0" />
   </padding>

</VBox>