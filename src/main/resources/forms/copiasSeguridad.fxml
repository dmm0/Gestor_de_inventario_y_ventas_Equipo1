<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox fx:controller="controladores.BackupController"
      maxHeight="-Infinity" maxWidth="-Infinity"
      minHeight="-Infinity" minWidth="-Infinity"
      prefHeight="400.0" prefWidth="600.0"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1">

   <children>

      <!-- HEADER -->
      <HBox prefHeight="41.0" prefWidth="600.0" style="-fx-background-color: #A3E0E6;">
         <children>
            <Label text="Copias de Seguridad (Respaldo del Sistema)">
               <font>
                  <Font size="16.0" />
               </font>
               <padding>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </padding>
            </Label>
         </children>
      </HBox>

      <!-- CONTENIDO -->
      <ScrollPane fitToWidth="true" prefHeight="355.0" prefWidth="600.0">
         <content>

            <VBox spacing="15.0" padding="20.0">

               <Label text="Seleccionar tipo de respaldo">
                  <font><Font size="14.0"/></font>
               </Label>

               <!-- RADIO BUTTONS -->
               <VBox spacing="10.0">
                  <children>
                     <RadioButton fx:id="rbCompleto" text="Respaldo Completo (Recomendado)" />
                     <RadioButton fx:id="rbVentas" text="Solo Ventas" />
                     <RadioButton fx:id="rbInventario" text="Solo Inventario" />
                     <RadioButton fx:id="rbClientes" text="Solo Clientes" />
                  </children>
               </VBox>

               <Label text="Ubicación de guardado">
                  <font><Font size="14.0"/></font>
               </Label>

               <!-- RUTA -->
               <VBox spacing="8.0">
                  <children>
                     <Label text="Ruta de destino:" />
                     <TextField fx:id="txtRuta" editable="false" />
                     <Button text="Seleccionar ubicación / carpeta"
                             onAction="#seleccionarCarpeta"/>
                  </children>
               </VBox>

               <Separator/>

               <!-- ACCIONES -->
               <HBox alignment="CENTER" spacing="15.0">
                  <children>
                     <Button text="Generar Copia" onAction="#generarBackup"/>
                     <Button text="Cancelar" onAction="#cerrarVentana"/>
                  </children>
               </HBox>

            </VBox>

         </content>
      </ScrollPane>

   </children>
</VBox>
