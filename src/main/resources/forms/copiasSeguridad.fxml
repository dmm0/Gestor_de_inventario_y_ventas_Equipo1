<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox fx:controller="controladores.CopiasSeguridadController"
      prefHeight="400.0" prefWidth="600.0"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1">

   <!-- HEADER -->
   <children>
       <Button text="← Menú"
                        onAction="#regresarMenu"
                        style="-fx-background-color: #A3E0E6; -fx-cursor: hand;"/>
        <Separator/>
      <HBox prefHeight="41.0" style="-fx-background-color: #A3E0E6;">
         <children>
            <Label text="Copias de Seguridad (Respaldo del Sistema)">
               <font>
                  <Font size="16.0"/>
               </font>
               <padding>
                  <Insets top="10" right="10" bottom="10" left="10"/>
               </padding>
            </Label>
         </children>
      </HBox>

      <!-- CONTENIDO -->
      <ScrollPane fitToWidth="true">
         <content>

            <VBox spacing="20.0">
               <padding>
                  <Insets top="20" right="20" bottom="20" left="20"/>
               </padding>

               <Label text="Seleccionar tipo de respaldo">
                  <font><Font size="14.0"/></font>
               </Label>

               <VBox spacing="10.0">
                  <children>
                     <RadioButton fx:id="rbCompleto" text="Respaldo Completo (Recomendado)" />
                     <RadioButton fx:id="rbVentas" text="Solo Ventas" />
                     <RadioButton fx:id="rbInventario" text="Solo Inventario" />
                     <RadioButton fx:id="rbClientes" text="Solo Clientes" />
                  </children>
               </VBox>

               <Label text="Ubicación de guardado">
                  <font><Font size="14.0"/></font>
               </Label>

               <VBox spacing="8.0">
                  <children>
                     <Label text="Ruta de destino:" />
                     <TextField fx:id="txtRuta" editable="false" />
                     <Button text="Seleccionar ubicación / carpeta"
                             onAction="#seleccionarCarpeta"/>
                  </children>
               </VBox>

               <Separator/>

<HBox alignment="CENTER" spacing="15.0">
    <children>
        <Button text="Generar Copia" onAction="#generarBackup" 
                style="-fx-background-color: #A3E0E6; -fx-font-weight: bold; -fx-cursor: hand;"/>
    </children>
</HBox>

            </VBox>

         </content>
      </ScrollPane>

   </children>
</VBox>