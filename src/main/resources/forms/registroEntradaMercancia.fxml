<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="500.0"
      prefWidth="650.0"
      spacing="10.0"
      style="-fx-background-color: white;"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controladores.RegistroEntradaMercanciaController">

   <children>

      <!-- ENCABEZADO -->
      <HBox alignment="CENTER_LEFT"
            prefHeight="50.0"
            spacing="10.0"
            style="-fx-background-color: #A3E0E6;">

         <children>

            <Button onAction="#regresarMenu"
                    style="-fx-background-color: #A3E0E6; -fx-font-weight: bold; -fx-cursor: hand;"
                    text="← Menú" />

            <Separator orientation="VERTICAL" />

            <Label text="Entrada de Mercancía">

               <font>
                  <Font name="System Bold" size="18.0" />
               </font>

            </Label>

         </children>

         <padding>
            <Insets left="15.0" />
         </padding>

      </HBox>

      <!-- CONTENIDO -->
      <VBox spacing="10.0">

         <children>

            <!-- BUSCADOR -->
            <HBox spacing="10.0">

               <children>

                  <TextField fx:id="txtBusqueda"
                             promptText="Buscar por ID o Nombre..."
                             HBox.hgrow="ALWAYS" />

                  <Button onAction="#buscarProducto"
                          text="Buscar" />

               </children>

            </HBox>

            <!-- TABLA -->
            <TableView fx:id="tablaProductos"
                       prefHeight="250.0">

               <columns>

                  <TableColumn fx:id="colId"
                               prefWidth="60"
                               text="ID" />

                  <TableColumn fx:id="colNombre"
                               prefWidth="250"
                               text="Nombre" />

                  <TableColumn fx:id="colStock"
                               prefWidth="100"
                               text="Stock Actual" />

                  <TableColumn fx:id="colPrecio"
                               prefWidth="100"
                               text="Precio" />

               </columns>

            </TableView>

            <!-- ENTRADA -->
            <HBox alignment="CENTER"
                  spacing="15.0"
                  style="-fx-background-color: #f4f4f4; -fx-padding: 10;">

               <children>

                  <Label text="Cantidad a ingresar:" />

                  <TextField fx:id="txtCantidadEntrada"
                             prefWidth="80.0"
                             promptText="0.0" />

                  <Button onAction="#registrarEntrada"
                          style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"
                          text="REGISTRAR ENTRADA" />
                  
                   <Button onAction="#abrirNuevoProducto"
              style="-fx-background-color: #2196F3; -fx-text-fill: white;"
              text="+ NUEVO PRODUCTO"/>
    <Button
    onAction="#modificarProducto"
    text="MODIFICAR"
    style="-fx-background-color: #FFC107;
           -fx-text-fill: white;" />

<Button
    onAction="#eliminarProducto"
    text="ELIMINAR"
    style="-fx-background-color: #f44336;
           -fx-text-fill: white;" />
               </children>

            </HBox>

         </children>

         <padding>
            <Insets bottom="15.0"
                    left="15.0"
                    right="15.0"
                    top="10.0" />
         </padding>

      </VBox>

   </children>

</VBox>