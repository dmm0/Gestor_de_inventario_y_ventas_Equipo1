<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="500.0" prefWidth="600.0"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controladores.DatosFacturarController">

    <children>

        <!-- HEADER -->
        <HBox style="-fx-background-color: #B7E1EB;" spacing="10">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>

            <children>

                <!-- BOTÓN REGRESAR -->
                <Button text="← Menú"
                        onAction="#regresarMenu"
                        style="-fx-background-color: #A3E0E6; -fx-cursor: hand;"/>

                <Label text="Solicitud de Factura">
                    <font>
                        <Font size="18.0"/>
                    </font>
                </Label>

                <Button text="X" onAction="#cancelar">
                    <HBox.margin>
                        <Insets left="250"/>
                    </HBox.margin>
                </Button>

            </children>
        </HBox>

        <!-- CONTENIDO -->
        <ScrollPane fitToWidth="true">
            <content>
                <VBox spacing="15">
                    <padding>
                        <Insets top="20" right="20" bottom="20" left="20"/>
                    </padding>

                    <!-- Datos venta -->
                    <HBox>
                        <children>
                            <VBox>
                                <Label text="Venta Asociada"/>
                                <Label text="Venta 0000"/>
                            </VBox>

                            <VBox>
                                <Label text="Monto Total"/>
                                <Label text="MXN 000.00"/>
                                <HBox.margin>
                                    <Insets left="350"/>
                                </HBox.margin>
                            </VBox>
                        </children>
                    </HBox>

                    <Label text="Datos Fiscales del Cliente"/>

                    <!-- RFC -->
                    <VBox>
                        <Label text="RFC *"/>
                        <HBox spacing="10">
                            <TextField fx:id="txtRFC" promptText="MAXX000000XXX"/>
                            <Button text="Validar RFC" onAction="#validarRFC"/>
                        </HBox>
                    </VBox>

                    <!-- Nombre -->
                    <VBox>
                        <Label text="Nombre / Razón Social *"/>
                        <TextField fx:id="txtNombre"/>
                    </VBox>

                    <!-- Régimen -->
                    <VBox>
                        <Label text="Régimen Fiscal *"/>
                        <ComboBox fx:id="cbRegimen"/>
                    </VBox>

                    <!-- Uso CFDI -->
                    <VBox>
                        <Label text="Uso de CFDI *"/>
                        <ComboBox fx:id="cbUsoCFDI"/>
                    </VBox>

                    <!-- CP -->
                    <VBox>
                        <Label text="Código Postal *"/>
                        <TextField fx:id="txtCP"/>
                    </VBox>

                    <!-- Correo -->
                    <VBox>
                        <Label text="Correo Electrónico *"/>
                        <TextField fx:id="txtCorreo"/>
                    </VBox>

                    <!-- BOTONES -->
                    <HBox spacing="20">
                        <children>
                            <Button text="Guardar datos"
                                    onAction="#guardarDatos"
                                    style="-fx-background-color: #A3E0E6; -fx-font-weight: bold;"/>

                            <Button text="Cancelar"
                                    onAction="#cancelar"
                                    style="-fx-background-color: #FFCCCC;"/>
                        </children>
                    </HBox>

                </VBox>
            </content>
        </ScrollPane>

    </children>
</VBox>