<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="400.0" prefWidth="600.0" spacing="20.0"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controladores.AdminUsuariosController">

   <children>
      <Button text="← Menú"
                        onAction="#regresarMenu"
                        style="-fx-background-color: #A3E0E6; -fx-cursor: hand;"/>
      <Separator/>
      <HBox style="-fx-background-color: #A3E0E6;">
         <children>
            <Label text="Administración de Usuarios">
               <font>
                  <Font size="19.0" />
               </font>
               <padding>
                  <Insets top="10" right="10" bottom="10" left="10"/>
               </padding>
            </Label>
         </children>
      </HBox>

      <VBox>
         <children>
            <Label text="Acciones principales"/>
            <HBox spacing="15">
    <children>
        <Button fx:id="btn_crear_usuario" text="Crear Nuevo Usuario" onAction="#crearUsuario" 
                style="-fx-background-color: #A3E0E6; -fx-cursor: hand;"/>
    </children>
</HBox>
         </children>
         <padding>
            <Insets top="20" right="20" bottom="20" left="20"/>
         </padding>
      </VBox>

      <VBox>
         <children>
            <Label text="Usuarios Registrados en el Sistema:"/>

            <TableView fx:id="table_Usuarios">
               <columns>
                  <TableColumn fx:id="colUsuario" text="Usuario"/>
                  <TableColumn fx:id="colNombre" text="Nombre Real"/>
                  <TableColumn fx:id="colEstado" text="Estado"/>
                  <TableColumn fx:id="colAcciones" text="Acciones"/>
               </columns>
            </TableView>

         </children>
         <padding>
            <Insets top="20" right="20" bottom="20" left="20"/>
         </padding>
      </VBox>

   </children>

   <padding>
      <Insets top="20" right="20" bottom="20" left="20"/>
   </padding>

</VBox>