<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="600.0" prefWidth="450.0" spacing="0" 
      xmlns="http://javafx.com/javafx/21" 
      xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="controladores.EditarUsuarioController">

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
        <content>
            <VBox spacing="12">
                <padding>
                    <Insets bottom="20" left="20" right="20" top="20" />
                </padding>

                <Label style="-fx-font-size:18px; -fx-font-weight:bold;" text="Editar Perfil de Usuario" />

                <Label style="-fx-font-weight:bold;" text="Información Personal (Empleado)" />
                <Label text="Nombre Completo" />
                <TextField fx:id="txtNombre" />
                <Label text="Teléfono de Contacto" />
                <TextField fx:id="txtTelefono" />
                <Label text="Puesto / Cargo" />
                <TextField fx:id="txtPuesto" />
                <Label text="Correo Electrónico" />
                <TextField fx:id="txtCorreo" />

                <Separator />

                <Label style="-fx-font-weight:bold;" text="Credenciales de Sistema" />
                <Label text="Nombre de Usuario" />
                <TextField fx:id="txtUsuario" />
                <Label text="Estado de Cuenta" />
                <ComboBox fx:id="cbEstado" maxWidth="Infinity" />

                <Separator />

                <Label style="-fx-font-weight:bold;" text="Permisos y Roles" />
                <VBox fx:id="boxRoles" spacing="8">
                    <CheckBox text="Registrar Ventas" />
                    <CheckBox text="Generar Cotización" />
                    <CheckBox text="Datos para Facturar" />
                    <CheckBox text="Administración de Usuarios" />
                    <CheckBox text="Gestionar Inventario" />
                    <CheckBox text="Copias de Seguridad" />
                </VBox>

                <Separator />

                <Label text="Actualizar Contraseña (Dejar en blanco para no cambiar)" />
                <PasswordField fx:id="txtPassword" />
            </VBox>
        </content>
    </ScrollPane>

    <HBox alignment="CENTER_RIGHT" spacing="15" 
          style="-fx-background-color: #f8f9fa; -fx-padding: 15; -fx-border-color: #dee2e6; -fx-border-width: 1 0 0 0;">
        <Button onAction="#actualizar" 
                style="-fx-background-color: #007bff; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 20;" 
                text="Guardar Cambios" />
    </HBox>

</VBox>